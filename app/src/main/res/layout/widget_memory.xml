<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Combined Cinematic Bitmap (Background + Foreground) -->
    <ImageView
        android:id="@+id/widget_image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:layout_gravity="center" />

    <ImageView
        android:id="@+id/widget_gradient"
        android:layout_width="match_parent"
        android:layout_height="140dp"
        android:layout_gravity="bottom"
        android:src="@drawable/gradient_overlay" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:orientation="vertical"
        android:padding="20dp">

        <TextView
            android:id="@+id/widget_common_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Discover Nature"
            android:textColor="@android:color/white"
            android:shadowColor="#BB000000"
            android:shadowDx="2"
            android:shadowDy="2"
            android:shadowRadius="4"
            android:textSize="20sp"
            android:textStyle="bold"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_scientific_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tap to refresh"
            android:textColor="#EEEEEE"
            android:shadowColor="#BB000000"
            android:shadowDx="1"
            android:shadowDy="1"
            android:shadowRadius="2"
            android:textSize="14sp"
            android:textStyle="italic"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text=""
            android:textColor="#CCFFFFFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:textAllCaps="true"
            android:visibility="gone"
            tools:text="Scouting for more wildlife..."
            tools:visibility="visible" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_refresh_button"
        android:layout_width="40dp"
        android:layout_height="40dp"
        android:layout_gravity="bottom|end"
        android:layout_margin="12dp"
        android:padding="8dp"
        android:src="@drawable/ic_refresh_white_24dp"
        android:background="@drawable/widget_button_ripple"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="Refresh" />

</FrameLayout>

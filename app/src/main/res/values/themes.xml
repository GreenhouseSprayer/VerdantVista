    <style name="Theme.VerdantVista.Pattern" parent="Theme.VerdantVista">
        <item name="colorPrimary">@color/white</item>
        <item name="android:statusBarColor">@color/black</item>
        <item name="android:windowBackground">@color/black</item>
        <item name="colorSurface">@color/forest_surface</item>
        <item name="android:navigationBarColor">@color/black</item>
        <item name="android:colorBackground">@color/black</item>
    </style>

    <style name="Theme.VerdantVista.NoActionBar" parent="Theme.VerdantVista">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
    </style>

    <style name="Theme.VerdantVista.AppBarOverlay" parent="ThemeOverlay.Material3.Dark.ActionBar" />
    <style name="Theme.VerdantVista.PopupOverlay" parent="ThemeOverlay.Material3.Light" />

    <!-- Custom Dialog Theme to match the app's aesthetic -->
    <style name="Theme.VerdantVista.Dialog" parent="Theme.Material3.DayNight.Dialog">
        <item name="android:windowBackground">@android:color/transparent</item>
        <item name="android:windowIsFloating">true</item>
        <item name="android:windowContentOverlay">@null</item>
        <item name="materialAlertDialogTheme">@style/ThemeOverlay.VerdantVista.MaterialAlertDialog</item>
    </style>

    <style name="ThemeOverlay.VerdantVista.MaterialAlertDialog" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="colorSurface">#1E1E1E</item>
        <item name="colorOnSurface">@color/white</item>
        <item name="colorPrimary">?attr/colorPrimary</item>
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">#BDBDBD</item>
    </style>
</resources>

<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.VerdantVista" parent="Theme.Material3.DayNight.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/forest_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/forest_accent</item>
        <item name="colorOnSecondary">@color/black</item>

        <item name="android:statusBarColor">@color/forest_primary_variant</item>
        <item name="android:windowBackground">@drawable/app_background_cinematic</item>
        <item name="colorSurface">@color/forest_surface</item>
        <item name="android:colorBackground">@color/forest_background</item>

        <!-- Navigation bar -->
        <item name="android:navigationBarColor">@color/forest_background</item>

        <!-- Improved text and control colors for better visibility -->
        <item name="android:textColorPrimary">@color/white</item>
        <item name="android:textColorSecondary">@color/text_secondary_light</item>
        <item name="colorControlNormal">@color/control_normal_light</item>

        <!-- Material 3 essentials -->
        <item name="colorOnSurface">@color/white</item>
        <item name="colorOnBackground">@color/white</item>
    </style>

    <style name="Theme.VerdantVista.Forest" parent="Theme.VerdantVista" />

    <style name="Theme.VerdantVista.Desert" parent="Theme.VerdantVista">
        <item name="colorPrimary">@color/desert_primary</item>

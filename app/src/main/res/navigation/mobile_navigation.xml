<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mobile_navigation"
    app:startDestination="@+id/nav_discover">

    <fragment
        android:id="@+id/nav_discover"
        android:name="Verdant.Vista.ui.transform.TransformFragment"
        android:label="Discover"
        tools:layout="@layout/fragment_transform">
        <argument
            android:name="taxon_id"
            android:defaultValue="-1"
            app:argType="integer" />
    </fragment>

    <fragment
        android:id="@+id/nav_favorites"
        android:name="Verdant.Vista.ui.favorites.FavoritesFragment"
        android:label="Favorites"
        tools:layout="@layout/fragment_favorites">
        <action
            android:id="@+id/action_nav_favorites_to_nav_discover"
            app:destination="@id/nav_discover" />
    </fragment>

    <fragment
        android:id="@+id/nav_settings"
        android:name="Verdant.Vista.ui.settings.SettingsFragment"
        android:label="@string/menu_settings"
        tools:layout="@layout/fragment_settings" />

</navigation>
